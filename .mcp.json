{
  "mcpServers": {
    "emacs-mcp-core": {
      "command": "uv",
      "args": ["run", "python", "src/server.py", "functions-core.jsonl"],
      "env": {
        "PYTHONPATH": "src"
      }
    },
    "emacs-mcp-maximalist": {
      "command": "uv",
      "args": ["run", "python", "src/server.py", "functions-compact.jsonl"],
      "env": {
        "PYTHONPATH": "src"
      }
    }
  }
}
